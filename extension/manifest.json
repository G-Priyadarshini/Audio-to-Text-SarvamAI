{
  "manifest_version": 3,
  "name": "Audio to Text",
  "version": "1.0.0",
  "description": "Audio-to-Text transcription with microphone, tab capture, and file upload support",
  "permissions": [
    "storage",
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen",
    "audioCapture"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
